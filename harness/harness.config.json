{
  "$schema": "kakashi-harness",
  "$schemaVersion": "1.0.0",
  "name": "Kakashi's Harness",
  "description": "카카시 하네스 이용기록기(테스트겸)",
  "version": "1.4.0",
  "agents": [
    "tamer",
    "performance-scout",
    "test-sentinel",
    "security-guard",
    "build-doctor",
    "code-modernizer",
    "akka-net-specialist",
    "dotnet-concurrency-specialist",
    "dotnet-performance-analyst",
    "dotnet-benchmark-designer",
    "docfx-specialist",
    "roslyn-incremental-generator-specialist",
    "sage-deming"
  ],
  "engine": [
    "toad-summoning"
  ],
  "evaluation": {
    "base": {
      "agent": "sage-deming",
      "doctrine": "PDSA",
      "alwaysOn": true,
      "appliesTo": ["mode-a", "execution"],
      "exemptModes": ["mode-d-init", "tutorial"]
    },
    "followUp": {
      "trigger": "domain-match",
      "mappingDoc": "harness/knowledge/methodology/evaluation-base-pdsa.md"
    }
  },
  "created": "2026-04-19",
  "lastUpdated": "2026-04-24",
  "plugins": {
    "harness-kakashi": {
      "skills": ["harness-kakashi-creator", "harness-chakra-kakashi"]
    }
  }
}
